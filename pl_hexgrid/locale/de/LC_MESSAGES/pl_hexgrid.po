msgstr "Den Pfad beibehalten (sechseckiges Gitter)"

#: pl_hexgrid.py:187
msgid "Adjust image grid"
msgstr "Bildraster anpassen"

#: pl_hexgrid.py:188
msgid "Adjust the image grid to coincide with the center of hexagons (hexagonal grid only)"
msgstr "Das Bildraster so anpassen, dass es mit der Mitte der Sechsecke übereinstimmt"

