msgid "Snap centers to pixels"
msgstr "Mittelpunkte an Pixeln ausrichten"

#: pl_hexgrid.py:151
msgid "Stretch or compress slightly to snap hexagon centers to pixels"
msgstr "Leicht dehnen oder komprimieren, um die Mittelpunkte der Sechsecke an die Pixel anzupassen"

#: pl_hexgrid.py:153
msgid "\tFilter by accuracy"
msgstr "\tNach Genauigkeit filtern"

#: pl_hexgrid.py:154
msgid "Only output grids with sufficient snap accuracy"
msgstr "Nur Raster mit ausreichender Einrastgenauigkeit ausgeben"

#: pl_hexgrid.py:156
