#: pl_hexgrid.py:120
msgid "Hexagonal grid..."
msgstr "Sechseckiges Gitter..."

#: pl_hexgrid.py:124 pl_hexgrid.py:125
msgid "Creates an optimized hexagonal grid as a path. Stroking the path is optional."
msgstr "Erstellt ein optimiertes sechseckiges Gitter als Pfad. Das Nachzeichnen des Pfades ist optional."

#: pl_hexgrid.py:132
msgid "Hexagonal grid"
msgstr "Sechseckiges Gitter"

#: pl_hexgrid.py:133
msgid "Samples sheet"
msgstr "Musterblatt"

#: pl_hexgrid.py:134
msgid "Choose what to draw"
msgstr "Wählen Sie aus, was gezeichnet werden soll"

#: pl_hexgrid.py:134
msgid "Output"
msgstr "Ausgabe"

#: pl_hexgrid.py:136
msgid "\t\tSamples count"
msgstr "\t\tBeispielanzahl"

#: pl_hexgrid.py:137
msgid "Number of samples on the sample sheet"
msgstr "Anzahl der Beispiele auf dem Musterblatt"

#: pl_hexgrid.py:140
msgid "Width"
msgstr "Breite"

#: pl_hexgrid.py:141
msgid "Apothem"
msgstr "Apothem"

#: pl_hexgrid.py:142
